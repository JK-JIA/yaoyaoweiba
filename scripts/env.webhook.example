# 复制到服务器项目旁或项目内，例如：cp scripts/env.webhook.example .env.webhook
# systemd 里用 EnvironmentFile=.../.env.webhook 加载（勿提交含真实 Secret 的文件）
#
# 与 GitHub 仓库 Settings → Webhooks → Secret 完全一致
GITHUB_WEBHOOK_SECRET=请改为长随机串

# 监听（默认只绑 127.0.0.1，由 Nginx 对外提供 HTTPS）
GITHUB_WEBHOOK_HOST=127.0.0.1
GITHUB_WEBHOOK_PORT=8787

# URL 路径须与 Webhook 填写的 URL 路径一致，例如 https://你的域名/github/webhook
GITHUB_WEBHOOK_PATH=/github/webhook

# 仅 main 的 push 会触发（与 deploy-update.sh 常用分支一致）
GITHUB_WEBHOOK_BRANCH=main

# 可选：限制仓库，格式 owner/repo，与 GitHub 上 full name 一致
# GITHUB_WEBHOOK_REPO=JK-JIA/yaoyaoweiba
