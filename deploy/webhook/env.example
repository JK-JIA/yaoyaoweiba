# 复制为本目录下的 .env.webhook 后编辑（勿提交含真实 Secret 的文件）
#   cp env.example .env.webhook
#
# 与 GitHub 仓库 Settings → Webhooks → Secret 完全一致
GITHUB_WEBHOOK_SECRET=请改为长随机串

# 宿主机直接 node 跑脚本时用；本目录 compose 内由环境变量固定为 0.0.0.0，可不填
GITHUB_WEBHOOK_HOST=127.0.0.1
GITHUB_WEBHOOK_PORT=8787

# 须与 GitHub Payload URL 路径一致，例如 https://你的域名/github/webhook
GITHUB_WEBHOOK_PATH=/github/webhook

# 仅 main 的 push 会触发
GITHUB_WEBHOOK_BRANCH=main

# 可选：限制仓库 owner/repo
# GITHUB_WEBHOOK_REPO=JK-JIA/yaoyaoweiba
