# 使用说明：复制为 .env 后 Docker Compose 才会加载（不会自动读 .env.example）
#   cp .env.example .env
#
ADMIN_PASSWORD=yaoyaoweiba123
# 前端：留空则浏览器请求同域 /api，由 Next rewrites 转到后端（推荐部署）。
# 若前后端不同域且直连 API，再填完整 URL，例如 https://api.example.com
NEXT_PUBLIC_API_URL=
# Docker 构建前端镜像时，Next 反代目标（Compose 已默认 api:4000）
BACKEND_URL_FOR_PROXY=http://api:4000
# 后端 CORS：与浏览器地址栏的「协议+域名+端口」一致，生产必填；多个用英文逗号分隔
FRONTEND_URL=https://你的域名

# --- GitHub Webhook 自动部署 ---
# 见 README「GitHub Webhook 自动部署」与 scripts/env.webhook.example
# 使用 compose 中的 github-webhook 容器时，在根 .env 增加（与 deploy-update 一并 up 时保持 webhook）：
# COMPOSE_PROFILES=webhook
# Webhook 映射宿主机地址（可选，默认 127.0.0.1）：
# GITHUB_WEBHOOK_BIND=127.0.0.1
